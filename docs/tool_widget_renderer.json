{
  "name": "widgetRenderer",
  "arguments": {
    "title": "粒子黑洞",
    "description": "一个可交互的粒子黑洞 widget，可调粒子数量、引力和脉冲强度。",
    "html": "<div style=\"padding:12px 0 4px;display:grid;gap:12px;\">\n  <div style=\"display:grid;grid-template-columns:minmax(0,1fr) 220px;gap:12px;align-items:stretch;\">\n    <canvas id=\"hole\" style=\"width:100%;height:460px;border:1px solid var(--border);border-radius:calc(var(--radius) * 1.5);display:block;background:var(--card);\"></canvas>\n    <div style=\"display:grid;gap:12px;align-content:start;\">\n      <div class=\"card\" style=\"display:grid;gap:12px;\">\n        <div style=\"display:flex;justify-content:space-between;align-items:center;gap:8px;\">\n          <span class=\"badge primary\">singularity</span>\n          <span id=\"mode\" class=\"badge\">stable</span>\n        </div>\n        <div style=\"display:grid;gap:8px;\">\n          <label for=\"count\">粒子密度</label>\n          <input id=\"count\" type=\"range\" min=\"400\" max=\"2800\" step=\"100\" value=\"1400\" />\n          <label for=\"gravity\">引力强度</label>\n          <input id=\"gravity\" type=\"range\" min=\"20\" max=\"120\" step=\"1\" value=\"64\" />\n          <label for=\"pulse\">喷流脉冲</label>\n          <input id=\"pulse\" type=\"range\" min=\"0\" max=\"100\" step=\"1\" value=\"56\" />\n        </div>\n        <div style=\"display:flex;gap:8px;flex-wrap:wrap;\">\n          <button id=\"toggle\" class=\"primary\" type=\"button\">暂停</button>\n          <button id=\"burst\" type=\"button\">爆发</button>\n          <button id=\"reset\" type=\"button\">重置</button>\n        </div>\n      </div>\n      <div style=\"display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:12px;\">\n        <div style=\"background:var(--muted);border-radius:var(--radius);padding:12px;display:grid;gap:4px;\">\n          <span style=\"font-size:12px;color:var(--muted-foreground);\">轨道速度</span>\n          <span id=\"speedVal\" style=\"font-size:24px;font-weight:600;color:var(--foreground);\">0</span>\n        </div>\n        <div style=\"background:var(--muted);border-radius:var(--radius);padding:12px;display:grid;gap:4px;\">\n          <span style=\"font-size:12px;color:var(--muted-foreground);\">事件视界</span>\n          <span id=\"radiusVal\" style=\"font-size:24px;font-weight:600;color:var(--foreground);\">0</span>\n        </div>\n      </div>\n      <div style=\"background:var(--muted);border-radius:calc(var(--radius) * 1.5);padding:12px;display:grid;gap:6px;\">\n        <div style=\"height:6px;background:var(--background);border-radius:999px;overflow:hidden;\">\n          <div id=\"meter\" style=\"height:100%;width:42%;background:var(--primary);transition:width .2s ease;\"></div>\n        </div>\n        <div id=\"status\" style=\"font-size:12px;color:var(--muted-foreground);\">粒子正在坠入奇点，吸积盘保持稳定。</div>\n      </div>\n    </div>\n  </div>\n</div>\n<script>\nconst canvas = document.getElementById('hole');\nconst ctx = canvas.getContext('2d');\nconst countInput = document.getElementById('count');\nconst gravityInput = document.getElementById('gravity');\nconst pulseInput = document.getElementById('pulse');\nconst speedVal = document.getElementById('speedVal');\nconst radiusVal = document.getElementById('radiusVal');\nconst status = document.getElementById('status');\nconst meter = document.getElementById('meter');\nconst mode = document.getElementById('mode');\nconst toggle = document.getElementById('toggle');\nconst burst = document.getElementById('burst');\nconst reset = document.getElementById('reset');\nlet particles = [];\nlet running = true;\nlet boost = 0;\nlet tick = 0;\nconst palette = ['#8b5cf6','#38bdf8','#fb7185','#f59e0b'];\nfunction fit(){\n  const ratio = Math.max(window.devicePixelRatio || 1, 1);\n  const rect = canvas.getBoundingClientRect();\n  canvas.width = Math.round(rect.width * ratio);\n  canvas.height = Math.round(rect.height * ratio);\n  ctx.setTransform(ratio,0,0,ratio,0,0);\n}\nfunction spawn(){\n  const total = Number(countInput.value);\n  const w = canvas.clientWidth;\n  const h = canvas.clientHeight;\n  const cx = w / 2;\n  const cy = h / 2;\n  particles = Array.from({length: total}, () => {\n    const angle = Math.random() * Math.PI * 2;\n    const ring = Math.pow(Math.random(), 0.55);\n    const r = 34 + ring * Math.min(w, h) * 0.42;\n    const tilt = (Math.random() - 0.5) * 0.28;\n    return {\n      a: angle,\n      r,\n      z: tilt,\n      size: Math.random() * 2.2 + 0.4,\n      speed: 0.003 + Math.random() * 0.012,\n      drift: (Math.random() - 0.5) * 0.03,\n      hue: palette[Math.floor(Math.random() * palette.length)],\n      life: Math.random(),\n      cx, cy\n    };\n  });\n}\nfunction drawBackground(w,h,cx,cy,core){\n  ctx.fillStyle = '#05070f';\n  ctx.fillRect(0,0,w,h);\n  ctx.strokeStyle = 'rgba(148,163,184,0.12)';\n  ctx.lineWidth = 1;\n  for(let i=0;i<7;i++){\n    const rr = core + 24 + i * 26;\n    ctx.beginPath();\n    ctx.ellipse(cx,cy,rr,rr * 0.38,0,0,Math.PI * 2);\n    ctx.stroke();\n  }\n}\nfunction render(){\n  const w = canvas.clientWidth;\n  const h = canvas.clientHeight;\n  const cx = w / 2;\n  const cy = h / 2;\n  const gravity = Number(gravityInput.value);\n  const pulse = Number(pulseInput.value) / 100;\n  const core = 34 + gravity * 0.42;\n  drawBackground(w,h,cx,cy,core);\n  tick += 0.016;\n  const jet = Math.sin(tick * 2.2) * (12 + pulse * 60 + boost * 22);\n  ctx.save();\n  ctx.globalCompositeOperation = 'screen';\n  particles.forEach((p, i) => {\n    if (running) {\n      p.a += p.speed * (0.7 + gravity / 100) + p.drift * 0.01;\n      p.r -= 0.045 + gravity * 0.0009 + p.life * 0.03 + boost * 0.08;\n      p.life += 0.004;\n      if (p.r < core * 0.64 || p.r > Math.min(w, h) * 0.46) {\n        p.r = core + Math.random() * Math.min(w, h) * 0.42;\n        p.a = Math.random() * Math.PI * 2;\n        p.life = 0;\n      }\n    }\n    const swirl = p.a + p.r * 0.014;\n    const x = cx + Math.cos(swirl) * p.r;\n    const y = cy + Math.sin(swirl) * p.r * (0.24 + Math.abs(p.z) * 0.8);\n    const alpha = Math.max(0.08, 1 - p.r / (Math.min(w,h) * 0.52));\n    ctx.fillStyle = p.hue.replace(')', ' / ' + alpha.toFixed(2) + ')');\n    ctx.beginPath();\n    ctx.arc(x, y, p.size, 0, Math.PI * 2);\n    ctx.fill();\n    if (i % 28 === 0) {\n      ctx.strokeStyle = 'rgba(226,232,240,0.08)';\n      ctx.beginPath();\n      ctx.moveTo(x, y);\n      ctx.lineTo(cx + Math.cos(swirl - 0.2) * (p.r + 8), cy + Math.sin(swirl - 0.2) * (p.r + 8) * 0.35);\n      ctx.stroke();\n    }\n  });\n  ctx.restore();\n  ctx.fillStyle = 'rgba(245,158,11,0.22)';\n  ctx.fillRect(cx - 4, cy - 120 - jet, 8, 240 + jet * 2);\n  ctx.fillRect(cx - 2, cy - 160 - jet * 1.2, 4, 320 + jet * 2.4);\n  ctx.beginPath();\n  ctx.fillStyle = '#02040a';\n  ctx.arc(cx, cy, core, 0, Math.PI * 2);\n  ctx.fill();\n  ctx.strokeStyle = 'rgba(255,255,255,0.08)';\n  ctx.beginPath();\n  ctx.arc(cx, cy, core + 8, 0, Math.PI * 2);\n  ctx.stroke();\n  const velocity = Math.round((gravity * 1.9 + pulse * 48 + boost * 28));\n  speedVal.textContent = velocity + 'k';\n  radiusVal.textContent = Math.round(core * 2) + ' px';\n  const chaos = Math.min(100, Math.round(gravity * 0.55 + pulse * 36 + boost * 22));\n  meter.style.width = chaos + '%';\n  if (chaos < 45) {\n    status.textContent = '粒子正在坠入奇点，吸积盘保持稳定。';\n    mode.textContent = 'stable';\n  } else if (chaos < 75) {\n    status.textContent = '潮汐撕裂增强，喷流开始拉长。';\n    mode.textContent = 'charged';\n  } else {\n    status.textContent = '黑洞进入爆发态，粒子流被高速甩出。';\n    mode.textContent = 'eruption';\n  }\n  boost *= 0.986;\n  if (running) requestAnimationFrame(render);\n}\nfunction restart(){ fit(); spawn(); if (!running) { running = true; toggle.textContent = '暂停'; render(); } }\n[countInput, gravityInput, pulseInput].forEach(input => input.addEventListener('input', restart));\ntoggle.addEventListener('click', () => {\n  running = !running;\n  toggle.textContent = running ? '暂停' : '继续';\n  if (running) render();\n});\nburst.addEventListener('click', () => { boost = 1.8; if (!running) { running = true; toggle.textContent = '暂停'; render(); } });\nreset.addEventListener('click', () => { boost = 0; countInput.value = 1400; gravityInput.value = 64; pulseInput.value = 56; restart(); });\nwindow.addEventListener('resize', restart);\nfit(); spawn(); render();\n</script>"
  }
}